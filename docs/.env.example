# ==========================================
# ENV VARIABLES - MI NEGOCIO IA
# ==========================================

# --- Base de Datos ---
# Obligatoria: Sí. URL de conexión a PostgreSQL con extensión pgvector.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agente_pedidos?schema=public"

# --- Redis ---
# Obligatoria: Sí. Se usa para colas BullMQ y caché.
REDIS_URL="redis://localhost:6379"

# --- Seguridad ---
# Obligatoria: Sí. Clave de encriptación para tokens de OAuth (AES-256). Debe tener 32 caracteres exactos.
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef"
# Obligatoria: Sí. Secreto para firmar los JWT de sesión del dashboard.
JWT_SECRET="super_secret_jwt_key_change_in_prod"

# --- OpenAI ---
# Obligatoria: Sí. API Key para embeddings y chat completions.
OPENAI_API_KEY="sk-proj-..."

# --- Meta Webhooks ---
# Obligatoria: Sí. Token arbitrario que usarás en el panel de Meta para verificar el webhook.
# META WHATSAPP CLOUD API
META_VERIFY_TOKEN="cualquier_cadena_secreta_aqui"
META_APP_ID="123456789"
META_APP_SECRET="xxx"

# FACTURACIÓN (PAYMENT ENGINE)
PAYMENT_PROVIDER="STRIPE" # STRIPE, REDSYS, etc.
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
